# Render corpus binary artifacts are stored in git-lfs. `run.sh` reproducers stay plain text.
render/**/*.webp    filter=lfs diff=lfs merge=lfs -text
render/**/*.png     filter=lfs diff=lfs merge=lfs -text
render/**/*.jpg     filter=lfs diff=lfs merge=lfs -text
render/**/*.mp4     filter=lfs diff=lfs merge=lfs -text
render/**/*.actions filter=lfs diff=lfs merge=lfs -text
