#!/bin/bash

# (Re-)generate the committed `render/` corpus — see the "Render corpus" section in README.md for what each
# scene's leaf contains. Covers Empty, Default, res/examples, and all glTF samples under external/. Run from anywhere.
# Scenes render headless (no window) in a pool of persistent worker processes: each worker initializes the
# engine once and pulls scenes from a shared job spool (`--render-queue`), clearing the scene between jobs.
# Set JOBS to change the worker count.

set -uo pipefail

ScriptDir="$(cd "$(dirname "${0}")" && pwd)"
ProjectRootDir="$(dirname "${ScriptDir}")"
cd "${ProjectRootDir}"

Exe="build/MeshEditor"
RenderDir="render"
Jobs="${JOBS:-8}"

SceneTimeoutSecs=120 # Catches hangs. Renders are GPU-paced, not real-time, and parallel renders contend for the GPU.

# True if the scene with output basename $1 produced its visual artifact.
has_output() {
    [ -f "$1.png" ] || [ -f "$1.mp4" ]
}

# Build the Debug executable first (never release, per repo policy).
"${ScriptDir}/Build"

# The glTF portion of the corpus needs the sample submodules. Warn but continue if they're missing.
GltfRoots=()
for root in external/glTF-Sample-Assets external/glTF_Physics; do
    if [ -d "${root}" ] && [ -n "$(find "${root}" -type f \( -iname '*.gltf' -o -iname '*.glb' \) -print -quit 2>/dev/null)" ]; then
        GltfRoots+=("${root}")
    else
        echo "WARNING: '${root}' has no glTF samples (run: git submodule update --init ${root}). Skipping it." >&2
    fi
done

# Prepare one scene's leaf and queue it for rendering. $1: output basename under render/ (no extension).
# $2 (optional): MeshEditor arg selecting the scene. Leaf prep stays in this (serial) parent so the
# committed run.sh files are deterministic regardless of worker completion order.
entries=()
prepare_scene() {
    local out="$1" arg="${2-}"
    mkdir -p "$(dirname "${out}")"
    # Clear prior artifacts so failure detection is accurate and stale files never linger.
    # The glob covers per-material-variant images ("<name>.<variant>.png").
    rm -f "${out}.png" "${out}".*.png "${out}.jpg" "${out}.mp4" "${out}.actions" "${out}.log"
    # Always write the one-command reproducer, even if the render later fails, so the leaf is self-documenting.
    # It loads the source scene directly (no capture, no project-file regeneration — that's this script's job).
    {
        echo '#!/bin/bash'
        echo '# Load this scene in the app. Run from the repository root.'
        printf 'exec ./%s' "${Exe}"
        [ -n "${arg}" ] && printf ' %q' "${arg}"
        printf '\n'
    } > "$(dirname "${out}")/run.sh"
    chmod +x "$(dirname "${out}")/run.sh"
    entries+=("${out}"$'\t'"${arg}")
}

# Built-in scenes (no source file).
prepare_scene "${RenderDir}/Empty/Empty" --empty
prepare_scene "${RenderDir}/Default/Default"

# res/examples and every glTF sample, mirrored 1:1 under render/.
# glTF_Physics/tests/ are conformance unit tests (not demo samples): they render empty/degenerate and some
# hang the physics solver, so they're excluded.
prev_out=""
while IFS= read -r P; do
    [ -n "${P}" ] || continue
    out="${RenderDir}/${P%.*}"
    # A model with both .gltf and .glb in one directory collides on a single output leaf (the sort makes them
    # adjacent): they're the same scene, so render it once.
    [ "${out}" = "${prev_out}" ] && continue
    prev_out="${out}"
    prepare_scene "${out}" "${P}"
done < <(
    # Skip the redundant `glTF-Binary` and `glTF-Embedded` variant dirs: every such model also ships a
    # `glTF` variant that renders identically (same asset, just a different container/encoding), so those
    # renders would be duplicates.
    find res/examples ${GltfRoots[@]+"${GltfRoots[@]}"} -type f \( -iname '*.gltf' -o -iname '*.glb' \) \
        -not -path '*/glTF_Physics/tests/*' -not -path '*/glTF-Binary/*' -not -path '*/glTF-Embedded/*' 2>/dev/null | sort
)

echo "Rendering corpus into ${RenderDir}/ (${#entries[@]} scenes, ${Jobs} headless workers)..."

# Spool one `.job` file per scene. Workers claim jobs by atomic rename, so the pool load-balances itself.
Spool="$(mktemp -d "${TMPDIR:-/tmp}/MeshEditorRenderSpool.XXXXXX")"
trap 'rm -rf "${Spool}"' EXIT

# Write one numbered `.job` file per argument into the spool.
spool_jobs() {
    local i=0 entry
    for entry; do
        printf '%s\n' "${entry}" > "$(printf '%s/%04d.job' "${Spool}" "${i}")"
        i=$((i + 1))
    done
}

# Unclaimed jobs left in the spool.
count_jobs() { find "${Spool}" -maxdepth 1 -name '*.job' | wc -l; }

spool_jobs "${entries[@]}"

# Run the app on the spool, killing and respawning it when a scene hangs.
run_worker() {
    local fifo="${Spool}/worker$1.fifo" pid line read_status remaining
    mkfifo "${fifo}"
    while :; do
        remaining="$(count_jobs)"
        [ "${remaining}" -gt 0 ] || break
        "./${Exe}" --render-queue "${Spool}" -q >"${fifo}" &
        pid=$!
        exec 3<"${fifo}"
        while :; do
            IFS= read -r -t "${SceneTimeoutSecs}" -u 3 line
            read_status=$?
            [ "${read_status}" -eq 0 ] || break
            echo "  ${line}"
        done
        exec 3<&-
        [ "${read_status}" -gt 128 ] && kill -9 "${pid}" 2>/dev/null
        wait "${pid}" 2>/dev/null
        # An exit that claimed no job means the app can't start (or the queue drained meanwhile), so don't respawn into a crash loop.
        [ "$(count_jobs)" -eq "${remaining}" ] && break
    done
}

worker=1
while [ "${worker}" -le "${Jobs}" ]; do
    run_worker "${worker}" &
    worker=$((worker + 1))
done
wait

# Retry failures once through a single fresh worker (Metal device-loss).
retries=()
for entry in "${entries[@]}"; do
    has_output "${entry%%$'\t'*}" || retries+=("${entry}")
done
if [ "${#retries[@]}" -gt 0 ]; then
    rm -f "${Spool}"/*.job "${Spool}"/*.job.claimed
    for entry in "${retries[@]}"; do echo "  retrying ${entry%%$'\t'*}"; done
    spool_jobs "${retries[@]}"
    run_worker retry
fi

# Tally from the artifacts (worker output order is nondeterministic under parallelism).
rendered=0
skipped=0
skips=()
for entry in "${entries[@]}"; do
    out="${entry%%$'\t'*}"
    if has_output "${out}"; then
        rendered=$((rendered + 1))
    else
        skipped=$((skipped + 1))
        skips+=("${out}")
    fi
done

echo
echo "Done: ${rendered} rendered, ${skipped} skipped."
if [ "${skipped}" -gt 0 ]; then
    echo "Skipped:"
    for s in "${skips[@]}"; do echo "  ${s}"; done
fi
