#!/bin/bash

set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: $0 /path/to/Blender.app/Contents/Resources/<version>/datafiles/studiolights/world [output_dir]"
  exit 1
fi

if ! command -v ffmpeg >/dev/null 2>&1; then
  echo "ffmpeg is required but not found in PATH."
  exit 1
fi

src_dir="$1"
out_dir="${2:-res/images/studiolights/world}"

if [[ ! -d "$src_dir" ]]; then
  echo "Source directory not found: $src_dir"
  exit 1
fi

mkdir -p "$out_dir"

for exr in "$src_dir"/*.exr; do
  [[ -e "$exr" ]] || continue
  name="$(basename "$exr" .exr)"
  ffmpeg -y -loglevel error -i "$exr" "$out_dir/$name.hdr"
done

echo "Converted Blender world EXRs to HDR in: $out_dir"
