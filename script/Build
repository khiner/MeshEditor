#!/bin/bash

set -e

ScriptDir="$(cd "$(dirname "${0}")" && pwd)"
ProjectRootDir="$(dirname "${ScriptDir}")"

build_type="Debug"
target="MeshEditor"

for arg in "$@"; do
    case "$arg" in
        -r|--release) build_type="Release" ;;
        --test) target="MeshEditorTests" ;;
        *) echo "Unknown option: $arg" >&2; exit 1 ;;
    esac
done

echo "Building $target in $build_type mode..."
CC=clang CXX=clang++ cmake -G Ninja -S "${ProjectRootDir}" -B "${ProjectRootDir}/build" -DCMAKE_BUILD_TYPE="$build_type"
cmake --build "${ProjectRootDir}/build" --config "$build_type" --target "$target"
