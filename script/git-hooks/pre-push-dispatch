#!/bin/sh
# Runs the tracked corpus hook, then git-lfs (which uploads LFS objects), on the same stdin.
# Install: cp script/git-hooks/pre-push-dispatch .git/hooks/pre-push
command -v git-lfs >/dev/null 2>&1 || { printf >&2 "\n%s\n\n" "This repository is configured for Git LFS but 'git-lfs' was not found on your path."; exit 2; }
input="$(cat)"
printf '%s\n' "${input}" | "$(git rev-parse --show-toplevel)/script/git-hooks/pre-push" "$@" || exit $?
printf '%s\n' "${input}" | git lfs pre-push "$@"
